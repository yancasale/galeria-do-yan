<div id="modal" class="modal">
  <div class="modal-content">
    <button class="modal-close" aria-label="Close modal">×</button>

    <img id="modal-image" />

    <div class="modal-meta">
      <p id="modal-info"></p>
      <p id="modal-description"></p>
    </div>
  </div>
</div>

<style>
  .modal {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.85);
    display: none;
    align-items: center;
    justify-content: center;
    z-index: 1000;
    padding: 1.5rem;
  }

  .modal-content {
    position: relative;
    max-width: 900px;
    width: 100%;
    max-height: 90vh;
    background: #fff;
    padding: 1.5rem;
    border-radius: 10px;
    overflow-y: auto;
  }

  .modal img {
    width: 100%;
    max-height: 60vh;
    object-fit: contain;
    margin-bottom: 1rem;
  }

  .modal-meta {
    text-align: center;
  }

  .modal-meta h2 {
    margin: 0.5rem 0;
  }

  .modal-meta p {
    color: #666;
    line-height: 1.6;
  }

  @media (max-width: 600px) {
    .modal-content {
      padding: 1rem;
    }

    .modal-meta h2 {
      font-size: 1.2rem;
    }
  }

  .modal-close {
    position: absolute;
    top: 12px;
    right: 12px;

    width: 36px;
    height: 36px;

    border-radius: 50%;
    border: none;

    background: rgba(255, 255, 255, 0.9);
    backdrop-filter: blur(6px);

    color: #333;
    font-size: 1.4rem;

    display: flex;
    align-items: center;
    justify-content: center;

    cursor: pointer;
    z-index: 10;

    transition: all 0.2s ease;
  }

  .modal-close:hover {
    background: #000;
    color: #fff;
  }
</style>

<script>
  const modal = document.getElementById("modal");
  const modalImage = document.getElementById("modal-image");
  const modalTitle = document.getElementById("modal-title");
  const modalInfo = document.getElementById("modal-info");
  const modalDescription = document.getElementById("modal-description");
  const closeButton = document.querySelector(".modal-close");

  function closeModal() {
    modal.style.display = "none";
    modalImage.src = "";
    modal.classList.remove("active");
    modalImage.src = "";
    document.body.style.overflow = "";
  }

  window.openModal = (el, event) => {
    // If click came from filter UI, do nothing
    if (event && event.target.closest(".filter-wrapper")) {
      return;
    }

    // If card is hidden (filtered out), do nothing
    if (el.style.display === "none") return;

    const img = el.querySelector("img");
    if (!img) return;

    modalImage.src = img.src;

    modalInfo.textContent = `${el.dataset.type} · ${el.dataset.date}`;
    modalDescription.textContent = el.dataset.description || "";

    modal.style.display = "flex";
    modal.classList.add("active");
    document.body.style.overflow = "hidden";
  };

  // Click X
  closeButton.addEventListener("click", closeModal);

  // Click outside content
  modal.addEventListener("click", (e) => {
    if (e.target === modal) {
      closeModal();
    }
  });

  // ESC key
  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape" && modal.style.display === "flex") {
      closeModal();
    }
  });
</script>
